# Database (Neon - get from neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Resend (get from resend.com)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxx"

# The "from" email address (must be verified in Resend)
FROM_EMAIL="will@yourdomain.com"

# Vercel Cron security (generate any random string)
CRON_SECRET="generate-with: openssl rand -base64 32"

# Inbound webhook secret (optional, set this in Mailgun and here)
INBOUND_WEBHOOK_SECRET="your-mailgun-webhook-secret"

# Public app URL (for beneficiary links in the dashboard)
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
